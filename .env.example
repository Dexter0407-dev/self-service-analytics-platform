# ── Backend ─────────────────────────────────────────────────────────────────
DATA_STORAGE_DIR=/app/storage
MAX_UPLOAD_MB=50
CORS_ORIGINS=http://localhost:3000

# Storage backend: local (dev) or azure (production)
STORAGE_BACKEND=local

# Required only when STORAGE_BACKEND=azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=self-service-data

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
